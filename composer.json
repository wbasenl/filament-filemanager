{
    "name": "wbasenl/filament-filemanager",
    "description": "A full-featured file manager package for Laravel and Filament v5 with dual operating modes, drag-and-drop uploads, S3/MinIO support, and comprehensive security features.",
    "keywords": [
        "laravel",
        "filament",
        "file-manager",
        "storage",
        "s3",
        "minio",
        "upload",
        "media-library"
    ],
    "type": "library",
    "license": "GPL-3.0-or-later",
    "authors": [
        {
            "name": "Marcelo W. Guerra",
            "email": "contact@mwguerra.com",
            "homepage": "https://mwguerra.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "illuminate/contracts": "^12.0|^13.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test:parallel": "vendor/bin/pest --parallel",
        "test:coverage": "XDEBUG_MODE=coverage vendor/bin/pest --coverage",
        "test:coverage:html": "XDEBUG_MODE=coverage vendor/bin/pest --coverage-html tests/coverage",
        "test:parallel:coverage": "XDEBUG_MODE=coverage vendor/bin/pest --parallel --coverage",
        "build": "npm run build",
        "release": "bash scripts/release.sh"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "autoload": {
        "psr-4": {
            "Wbasenl\\MwguerraFileManager\\": "src/",
            "Wbasenl\\MwguerraFileManager\\Database\\Factories\\": "database/factories/",
            "Wbasenl\\MwguerraFileManager\\Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Wbasenl\\MwguerraFileManager\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Wbasenl\\MwguerraFileManager\\FileManagerServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
